// ============================================================
// AI Software Planning Agent — Prisma Schema
// Source of truth: specs/database.spec.md + specs/schema.spec.md
// Conventions: snake_case plural table names (via @@map),
//   snake_case columns (via @map), UUID v4 PKs, TIMESTAMPTZ.
// ============================================================

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// Enums
// ------------------------------------------------------------

enum WorkflowStage {
  init @map("init")
  requirement_analysis @map("requirement_analysis")
  requirement_clarification @map("requirement_clarification")
  multi_model_analysis @map("multi_model_analysis")
  requirement_synthesis @map("requirement_synthesis")
  feasibility_analysis @map("feasibility_analysis")
  risk_analysis @map("risk_analysis")
  mvp_compression @map("mvp_compression")
  platform_recommendation @map("platform_recommendation")
  planning_generation @map("planning_generation")
  completed @map("completed")
  failed @map("failed")
}

enum ProjectStatus {
  active @map("active")
  completed @map("completed")
  failed @map("failed")
}

enum ConversationStatus {
  active @map("active")
  closed @map("closed")
}

enum MessageRole {
  user @map("user")
  assistant @map("assistant")
  system @map("system")
}

enum StageStatus {
  pending @map("pending")
  running @map("running")
  completed @map("completed")
  failed @map("failed")
  skipped @map("skipped")
}

enum ExecutionStatus {
  success @map("success")
  failed @map("failed")
  timeout @map("timeout")
  cancelled @map("cancelled")
}

enum CallStatus {
  success @map("success")
  failed @map("failed")
  timeout @map("timeout")
  rate_limited @map("rate_limited")
}

enum ExportStatus {
  pending @map("pending")
  processing @map("processing")
  completed @map("completed")
  failed @map("failed")
}

enum ExportFormat {
  markdown @map("markdown")
  pdf @map("pdf")
  html @map("html")
  json @map("json")
}

enum ArtifactType {
  requirement_report @map("requirement_report")
  feasibility_report @map("feasibility_report")
  risk_report @map("risk_report")
  mvp_plan @map("mvp_plan")
  platform_recommendation @map("platform_recommendation")
  project_plan @map("project_plan")
  prd @map("prd")
  architecture @map("architecture")
  frontend_spec @map("frontend_spec")
  backend_spec @map("backend_spec")
  ai_coding_rules @map("ai_coding_rules")
}

enum LLMProvider {
  deepseek @map("deepseek")
  glm @map("glm")
  minimax @map("minimax")
}

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------

/// Project entity — root aggregate.
model Project {
  id               String          @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(200)
  original_idea    String           @db.Text
  status           ProjectStatus   @default(active) @map("status")
  current_stage    WorkflowStage   @default(init) @map("current_stage")
  requirement_text String?          @db.Text
  error_message    String?          @db.Text
  started_at       DateTime?        @db.Timestamptz
  completed_at     DateTime?        @db.Timestamptz
  created_at       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updated_at       DateTime         @map("updated_at") @db.Timestamptz
  deleted_at       DateTime?        @map("deleted_at") @db.Timestamptz

  conversations     Conversation[]
  workflow_states   WorkflowState[]
  workflow_executions WorkflowExecution[]
  analysis_results  AnalysisResult[]
  artifacts         Artifact[]
  exports           Export[]
  model_execution_logs ModelExecutionLog[]
  token_usage       TokenUsage?

  @@index([status])
  @@index([current_stage])
  @@index([created_at(sort: Desc)])
  @@index([deleted_at])
  @@map("projects")
}

/// Conversation session within a project.
model Conversation {
  id         String               @id @default(uuid()) @db.Uuid
  project_id String               @map("project_id") @db.Uuid
  status     ConversationStatus   @default(active) @map("status")
  created_at DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updated_at DateTime             @map("updated_at") @db.Timestamptz

  project  Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([project_id])
  @@index([project_id, status])
  @@map("conversations")
}

/// Individual message in a conversation.
model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversation_id String       @map("conversation_id") @db.Uuid
  role            MessageRole @map("role")
  content         String       @db.Text
  metadata        Json?
  created_at      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("messages")
}

/// Workflow stage state snapshot (one row per project+stage).
model WorkflowState {
  id            String       @id @default(uuid()) @db.Uuid
  project_id    String       @map("project_id") @db.Uuid
  stage         WorkflowStage @map("stage")
  status        StageStatus  @default(pending) @map("status")
  display_name  String       @map("display_name") @db.VarChar(100)
  progress      Json
  data_json     Json?        @map("data_json")
  error_message String?     @map("error_message") @db.Text
  started_at    DateTime?   @map("started_at") @db.Timestamptz
  completed_at  DateTime?   @map("completed_at") @db.Timestamptz
  created_at    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updated_at    DateTime    @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, stage])
  @@index([project_id])
  @@index([status])
  @@map("workflow_states")
}

/// Workflow execution history record.
model WorkflowExecution {
  id            String           @id @default(uuid()) @db.Uuid
  project_id    String           @map("project_id") @db.Uuid
  stage         WorkflowStage    @map("stage")
  status        ExecutionStatus  @map("status")
  started_at    DateTime         @map("started_at") @db.Timestamptz
  completed_at  DateTime?        @map("completed_at") @db.Timestamptz
  duration_ms   Int?             @map("duration_ms")
  error_message String?          @map("error_message") @db.Text
  retry_count   Int              @default(0) @map("retry_count")
  created_at    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  project          Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  analysis_results AnalysisResult[]
  model_execution_logs ModelExecutionLog[]

  @@index([project_id, started_at(sort: Desc)])
  @@index([project_id, stage])
  @@index([status])
  @@map("workflow_executions")
}

/// Stage analysis result (structured LLM output persisted).
model AnalysisResult {
  id             String         @id @default(uuid()) @db.Uuid
  project_id     String         @map("project_id") @db.Uuid
  execution_id   String?        @map("execution_id") @db.Uuid
  stage          WorkflowStage  @map("stage")
  result_type    String         @map("result_type") @db.VarChar(50)
  schema_name    String?        @map("schema_name") @db.VarChar(100)
  schema_version String?       @map("schema_version") @db.VarChar(30)
  content_json   Json          @map("content_json")
  content_text   String?       @map("content_text") @db.Text
  created_at     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  project    Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  execution  WorkflowExecution? @relation(fields: [execution_id], references: [id], onDelete: SetNull)

  @@index([project_id, stage])
  @@index([execution_id])
  @@index([created_at(sort: Desc)])
  @@map("analysis_results")
}

/// Generated artifact entity.
model Artifact {
  id                 String       @id @default(uuid()) @db.Uuid
  project_id         String       @map("project_id") @db.Uuid
  type               ArtifactType @map("type")
  type_display_name  String       @map("type_display_name") @db.VarChar(100)
  title              String       @db.VarChar(200)
  stage              WorkflowStage @map("stage")
  content            String       @db.Text
  file_path          String?      @map("file_path") @db.Text
  size_bytes         Int?         @map("size_bytes")
  format             String       @default("markdown") @map("format") @db.VarChar(20)
  created_at         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updated_at         DateTime     @map("updated_at") @db.Timestamptz
  deleted_at         DateTime?    @map("deleted_at") @db.Timestamptz

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  // Partial uniqueness (non-deleted rows) enforced via DB; here a plain
  // unique on (project_id, type) is too strict for soft-deleted dupes, so
  // we rely on application-layer guard + the index below for lookup perf.
  @@index([project_id])
  @@index([project_id, type])
  @@index([type])
  @@index([deleted_at])
  @@map("artifacts")
}

/// Export task entity.
model Export {
  id                   String        @id @default(uuid()) @db.Uuid
  project_id           String        @map("project_id") @db.Uuid
  format               ExportFormat  @map("format")
  status               ExportStatus  @default(pending) @map("status")
  artifact_types       Json          @map("artifact_types")
  artifact_count       Int           @default(0) @map("artifact_count")
  file_path            String?       @map("file_path") @db.Text
  file_size_bytes      Int?          @map("file_size_bytes")
  download_token_hash  String?       @map("download_token_hash") @db.VarChar(128)
  download_expires_at  DateTime?     @map("download_expires_at") @db.Timestamptz
  error_message        String?       @map("error_message") @db.Text
  created_at           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  completed_at         DateTime?     @map("completed_at") @db.Timestamptz

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, created_at(sort: Desc)])
  @@index([status])
  @@index([download_token_hash])
  @@map("exports")
}

/// LLM call execution log (cost & token accounting).
model ModelExecutionLog {
  id                 String        @id @default(uuid()) @db.Uuid
  project_id         String        @map("project_id") @db.Uuid
  execution_id       String?       @map("execution_id") @db.Uuid
  stage              WorkflowStage @map("stage")
  provider_name      LLMProvider   @map("provider_name")
  model_id           String        @map("model_id") @db.VarChar(100)
  status             CallStatus    @map("status")
  attempt_number     Int           @default(1) @map("attempt_number")
  prompt_text        String        @map("prompt_text") @db.Text
  prompt_version_id  String?       @map("prompt_version_id") @db.Uuid
  response_text      String?       @map("response_text") @db.Text
  structured_output  Json?         @map("structured_output")
  input_tokens       Int           @default(0) @map("input_tokens")
  output_tokens      Int           @default(0) @map("output_tokens")
  cost_input         Decimal       @default(0) @map("cost_input") @db.Decimal(10, 6)
  cost_output        Decimal       @default(0) @map("cost_output") @db.Decimal(10, 6)
  cost_total         Decimal       @default(0) @map("cost_total") @db.Decimal(10, 6)
  latency_ms         Int?          @map("latency_ms")
  error_code         String?       @map("error_code") @db.VarChar(50)
  error_message      String?       @map("error_message") @db.Text
  created_at         DateTime      @default(now()) @map("created_at") @db.Timestamptz

  project        Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  execution      WorkflowExecution? @relation(fields: [execution_id], references: [id], onDelete: SetNull)
  prompt_version PromptVersion?    @relation(fields: [prompt_version_id], references: [id], onDelete: SetNull)

  @@index([project_id, created_at(sort: Desc)])
  @@index([execution_id])
  @@index([stage])
  @@index([provider_name])
  @@index([status])
  @@map("model_execution_logs")
}

/// Prompt version record (immutable, content-addressed by hash).
model PromptVersion {
  id           String       @id @default(uuid()) @db.Uuid
  prompt_name  String       @map("prompt_name") @db.VarChar(100)
  version      String       @db.VarChar(30)
  content_hash String       @map("content_hash") @db.VarChar(128)
  description  String?      @db.Text
  created_at   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  model_execution_logs ModelExecutionLog[]

  @@unique([prompt_name, version])
  @@index([created_at(sort: Desc)])
  @@map("prompt_versions")
}

/// Per-project token/cost aggregate (1:1 with project).
model TokenUsage {
  id                  String   @id @default(uuid()) @db.Uuid
  project_id          String   @unique @map("project_id") @db.Uuid
  total_input_tokens  Int      @default(0) @map("total_input_tokens")
  total_output_tokens Int      @default(0) @map("total_output_tokens")
  total_tokens        Int      @default(0) @map("total_tokens")
  total_cost          Decimal  @default(0) @map("total_cost") @db.Decimal(12, 6)
  call_count          Int      @default(0) @map("call_count")
  success_count       Int      @default(0) @map("success_count")
  failed_count        Int      @default(0) @map("failed_count")
  timeout_count       Int      @default(0) @map("timeout_count")
  rate_limited_count  Int      @default(0) @map("rate_limited_count")
  avg_latency_ms      Int?     @map("avg_latency_ms")
  updated_at          DateTime @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([total_cost(sort: Desc)])
  @@map("token_usage")
}