{
  "name": "@ai-planning/database",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prisma/schema.prisma": "./prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && rm -rf dist/generated && cp -r src/generated dist/generated",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\"",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx src/seed/index.ts",
    "diagnose:project": "tsx src/diagnose-project.ts"
  },
  "prisma": {
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.5",
    "typescript": "^5.5.0"
  }
}
