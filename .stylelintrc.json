{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "no-empty-source": null,
    "import-notation": null,
    "at-rule-no-unknown": [
      true,
      { "ignoreAtRules": ["tailwind", "apply", "layer", "config", "plugin", "utility"] }
    ],
    "selector-class-pattern": null
  },
  "ignoreFiles": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**"
  ]
}
