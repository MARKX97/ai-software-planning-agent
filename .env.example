# ============================================================
# AI Software Planning Agent — Environment Variables
# Copy to .env and fill in real values. Do NOT commit .env.
# ============================================================

# ---- App ----
# API server port (default 3001)
API_PORT=3001
# Web server port (default 3000)
WEB_PORT=3000
# Shared API key for authenticating API requests. Leave empty to disable auth in dev.
API_KEY=
# Optional export-token secret. Defaults to API_KEY, or an ephemeral dev secret if both are empty.
DOWNLOAD_TOKEN_SECRET=
# Base directory for generated artifacts (default: ./data)
DATA_DIR=./data
# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=DEBUG

# ---- Database ----
# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_planning_agent?schema=public

# ---- LLM (Baishan OpenAI-compatible API) ----
# Leave the key empty for the local demo. Fill it only when testing the real service.
BAISHAN_BASE_URL=https://api.baishan.com/v1
BAISHAN_API_KEY=
BAISHAN_MODEL_DEEPSEEK=deepseek-v4-pro
BAISHAN_MODEL_GLM=glm-5.1
BAISHAN_MODEL_MINIMAX=minimax-m2.5
# Paid smoke test opt-in. Keep disabled for normal development and CI.
RUN_REAL_BAISHAN_STREAM=0

# ---- Cost Control ----
# Max cost in CNY per project (default: 5.00)
COST_MAX_COST_PER_PROJECT=5.00
