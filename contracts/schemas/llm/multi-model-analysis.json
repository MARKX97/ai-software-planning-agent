{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MultiModelAnalysisResult",
  "description": "多模型分析阶段输出——每个模型独立分析的结果",
  "type": "object",
  "properties": {
    "model_name": { "type": "string", "description": "模型名称" },
    "requirement_points": { "type": "array", "items": { "$ref": "requirement-point.json" }, "description": "该模型识别出的需求点" },
    "strengths": { "type": "array", "items": { "type": "string" }, "description": "该方案的优势" },
    "weaknesses": { "type": "array", "items": { "type": "string" }, "description": "该方案的劣势" },
    "unknowns": { "type": "array", "items": { "type": "string" }, "description": "不确定性项" },
    "recommendation": { "type": "string", "description": "该模型的推荐方向" }
  },
  "required": ["model_name", "requirement_points", "strengths", "weaknesses", "unknowns", "recommendation"]
}